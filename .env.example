# Optional. Defaults to INFO. Use DEBUG to see per-request API details
# (Gmail, Calendar, Sheets, YNAB).
MGDIO_LOG_LEVEL=INFO

# Optional. Set to 1 to run the opt-in integration tests that hit real
# external APIs (Gmail, Calendar, Sheets, YNAB). They require a completed
# auth flow on this machine. Leave unset normally; the standard unit suite
# uses in-memory fakes and never touches your real accounts.
MGDIO_RUN_INTEGRATION=

# Optional. Override the YNAB integration test recipient/payer for any
# tests that need a target address. Defaults to the authenticated account.
MGDIO_INTEGRATION_TO=
