# Optional. Defaults to INFO. Use DEBUG to see per-request API details
# (Gmail, Calendar, Sheets, YNAB, Whoop).
MGDIO_LOG_LEVEL=INFO

# Optional. Set to 1 to run the opt-in integration tests that hit real
# external APIs (Gmail, Calendar, Sheets, YNAB, Whoop). They require a
# completed auth flow on this machine. Leave unset normally; the standard
# unit suite uses in-memory fakes and never touches your real accounts.
MGDIO_RUN_INTEGRATION=

# Optional. Override the YNAB integration test recipient/payer for any
# tests that need a target address. Defaults to the authenticated account.
MGDIO_INTEGRATION_TO=

# Optional. The OAuth redirect URI for `mgdio auth whoop`. Must match
# exactly what's registered in your Whoop developer app. Defaults to
# http://localhost:8765/callback -- only set this if you registered a
# different port or path.
MGDIO_WHOOP_REDIRECT_URI=http://localhost:8765/callback
